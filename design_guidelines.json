  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons.",
    "Install 'framer-motion' for animations.",
    "Install 'clsx' and 'tailwind-merge' for class handling.",
    "Use 'Playfair Display' from Google Fonts for Headings.",
    "Use 'Manrope' from Google Fonts for Body.",
    "Use 'Courier Prime' from Google Fonts for Script text.",
    "Implement a global 'noise' texture overlay using CSS fixed position pointer-events-none.",
    "Ensure all text has sufficient contrast (APCA compliant).",
    "Use the Bento Grid layout for the 'Breakdown' results page.",
    "For the 'Memorization Mode', create a focused, distraction-free full-screen overlay.",
    "Use the 'Spotlight' effect (radial gradient that follows mouse or fixed) on cards.",
    "Add 'data-testid' to all interactive elements."
  ],
  "universal_guidelines": [
    "Dark mode ONLY. Do not implement light mode toggle unless critical.",
    "Avoid gradients on text. Keep text crisp off-white.",
    "Use 24px-32px padding inside cards. Don't cram content.",
    "Micro-interactions: Buttons should scale down (0.98) on click.",
    "Inputs should have a subtle glow on focus.",
    "Scrollbars: Custom thin scrollbar in Zinc-800."
  ]
}