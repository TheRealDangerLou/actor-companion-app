{
  "design_system": {
    "identity": {
      "name": "Actor's Companion",
      "metaphor": "The Black Box Theater",
      "emotion": "Focused, Intimate, Professional, Dramatic",
      "theme_mode": "dark"
    },
    "colors": {
      "palette": {
        "background": {
          "default": "#09090b",
          "paper": "#18181b",
          "subtle": "#27272a"
        },
        "text": {
          "primary": "#fafafa",
          "secondary": "#a1a1aa",
          "muted": "#52525b"
        },
        "accent": {
          "primary": "#f59e0b",
          "secondary": "#e11d48",
          "tertiary": "#3b82f6"
        },
        "border": {
          "default": "#27272a",
          "active": "#52525b"
        }
      },
      "usage": {
        "primary_action": "bg-amber-500 hover:bg-amber-600 text-black font-bold",
        "secondary_action": "bg-zinc-800 hover:bg-zinc-700 text-white",
        "destructive": "bg-rose-900/20 text-rose-500 hover:bg-rose-900/40 border border-rose-900",
        "card_surface": "bg-zinc-950/50 border border-zinc-800 backdrop-blur-sm"
      }
    },
    "typography": {
      "fonts": {
        "heading": {
          "family": "Playfair Display",
          "weights": ["600", "700", "900"],
          "fallback": "serif"
        },
        "body": {
          "family": "Manrope",
          "weights": ["400", "500", "600"],
          "fallback": "sans-serif"
        },
        "script": {
          "family": "Courier Prime",
          "weights": ["400", "700"],
          "fallback": "monospace"
        }
      },
      "scale": {
        "h1": "text-4xl md:text-6xl font-black tracking-tight",
        "h2": "text-3xl md:text-4xl font-bold tracking-tight",
        "h3": "text-xl md:text-2xl font-semibold",
        "body": "text-base leading-relaxed text-zinc-300",
        "script_text": "text-lg font-mono leading-relaxed"
      }
    },
    "layout": {
      "grid_system": "Bento Grid (CSS Grid)",
      "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
      "spacing": {
        "section": "py-24",
        "element": "gap-6"
      },
      "radius": {
        "default": "rounded-lg",
        "button": "rounded-md",
        "card": "rounded-xl"
      }
    },
    "visual_enhancers": {
      "effects": [
        "Spotlight Gradients: Radial gradients mimicking stage lights",
        "Grain Texture: Subtle noise overlay for filmic feel",
        "Glassmorphism: High blur, low opacity for modals/overlays"
      ],
      "shadows": {
        "glow": "shadow-[0_0_30px_-5px_rgba(245,158,11,0.15)]",
        "card": "shadow-xl shadow-black/20"
      }
    }
  },
  "components": {
    "Button": {
      "specs": "Sharp or slightly rounded. High contrast. Hover lifts slightly.",
      "variants": ["solid-amber", "outline-zinc", "ghost-white"]
    },
    "Card": {
      "specs": "Dark zinc background. 1px border. Inner padding p-6 or p-8.",
      "variants": ["interactive-hover", "static-display"]
    },
    "Input": {
      "specs": "bg-zinc-900/50 border-zinc-800 focus:border-amber-500 focus:ring-1 focus:ring-amber-500 placeholder:text-zinc-600"
    },
    "Badge": {
      "specs": "rounded-full px-3 py-1 text-xs font-medium tracking-wide uppercase"
    }
  },
